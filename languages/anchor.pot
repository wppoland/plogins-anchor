msgid "Display"
msgstr ""

#: src/Admin/Settings.php:121
msgid "Enable the bar"
msgstr ""

#: src/Admin/Settings.php:122
msgid "The master switch. When off, the sticky bar never renders and its CSS/JS are not loaded — zero front-end impact."
msgstr ""

#: src/Admin/Settings.php:133
msgid "Show the sticky add-to-cart bar on single product pages."
msgstr ""

#: src/Admin/Settings.php:139
msgid "Position"
msgstr ""

#: src/Admin/Settings.php:140
msgid "Bottom is the most common and works well on mobile. Top suits stores with a sticky header you want to complement."
msgstr ""

